# ============================================================
# Railway — staging
# ============================================================
# أ) على موقع Railway (خدمة التطبيق → Variables) — لا في ملف .env المحلي:
#
#   DATABASE_URL = ${{MySQL.MYSQL_URL}}
#   (Add Reference → MySQL → MYSQL_URL)
#
# ب) القيم التي تظهر في خدمة MySQL → Variables (للمرجع أو الاتصال الخارجي):
# ============================================================

MYSQLHOST=
MYSQLPORT=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
MYSQL_URL=

# التطبيق يقرأ DATABASE_URL فقط — على Railway اربطه بـ MYSQL_URL كما في (أ)
DATABASE_URL=

NODE_ENV=production
JWT_SECRET=generate_a_random_64_char_hex_secret_here

USE_LOCAL_STORAGE=true
LOCAL_STORAGE_DIR=/app/uploads

VITE_APP_TITLE=منصة الوحدة القانونية - مصرف الرافدين

# أول نشر فقط — ينشئ admin: nayef / admin1987 ثم احذف هذا المتغير
SEED_ADMIN_ON_START=1

# Railway يضبط CORS تلقائياً عبر RAILWAY_PUBLIC_DOMAIN
# CORS_ORIGINS=https://your-service.up.railway.app

# بناء APK بعد النشر (على جهازك):
# CAP_SERVER_URL=https://your-service.up.railway.app
# VITE_API_URL=https://your-service.up.railway.app
